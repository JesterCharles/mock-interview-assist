# iac/cloudrun/dummy.env.example
# Template for Phase 45 Dockerfile smoke test (INFRA-07, D-15).
# Copy to dummy.env (gitignored) before running scripts/verify-phase-45.sh.
#
# These are PLACEHOLDERS — they are NOT valid credentials. The smoke test
# intentionally expects /api/health to return 503 (db disconnected, judge0
# unreachable) as proof the container booted (Option C per 45-RESEARCH.md
# §Pitfall 4). Full-green health is a Phase 47 gate.
#
# DO NOT replace with real values and commit.

# Database (Prisma). Invalid — will cause checks.db=disconnected in /api/health.
DATABASE_URL=postgresql://u:p@127.0.0.1:5432/nonexistent?connection_limit=5
DIRECT_URL=postgresql://u:p@127.0.0.1:5432/nonexistent

# Supabase (unused in smoke — app boots without hitting Supabase on /api/health).
NEXT_PUBLIC_SUPABASE_URL=https://dummy.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=dummy-publishable
SUPABASE_SECRET_KEY=dummy-secret

# External APIs — unused by /api/health.
OPENAI_API_KEY=sk-dummy
RESEND_API_KEY=re-dummy
GITHUB_TOKEN=ghp_dummy

# Public config.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_EMAILS=admin@example.com

# Judge0. Invalid — will cause checks.judge0=unreachable (expected).
JUDGE0_URL=http://127.0.0.1:9999
JUDGE0_AUTH_TOKEN=dummy-token
CODING_CHALLENGES_ENABLED=false
