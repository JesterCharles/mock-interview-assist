{
  "displayName": "NLM Production",
  "mosaicLayout": {
    "columns": 12,
    "tiles": [
      {
        "width": 6, "height": 4, "xPos": 0, "yPos": 0,
        "widget": {
          "title": "Request count (${env})",
          "xyChart": {
            "dataSets": [{
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"run.googleapis.com/request_count\" resource.type=\"cloud_run_revision\" resource.labels.project_id=\"${project_id}\"",
                  "aggregation": {"alignmentPeriod": "60s", "perSeriesAligner": "ALIGN_RATE", "crossSeriesReducer": "REDUCE_SUM", "groupByFields": ["resource.labels.service_name"]}
                }
              },
              "plotType": "LINE"
            }]
          }
        }
      },
      {
        "width": 6, "height": 4, "xPos": 6, "yPos": 0,
        "widget": {
          "title": "Request latency p50/p95/p99 (${env})",
          "xyChart": {
            "dataSets": [
              {"timeSeriesQuery": {"timeSeriesFilter": {"filter": "metric.type=\"run.googleapis.com/request_latencies\" resource.type=\"cloud_run_revision\" resource.labels.project_id=\"${project_id}\"", "aggregation": {"alignmentPeriod": "60s", "perSeriesAligner": "ALIGN_PERCENTILE_50", "crossSeriesReducer": "REDUCE_MEAN"}}}, "plotType": "LINE", "legendTemplate": "p50"},
              {"timeSeriesQuery": {"timeSeriesFilter": {"filter": "metric.type=\"run.googleapis.com/request_latencies\" resource.type=\"cloud_run_revision\" resource.labels.project_id=\"${project_id}\"", "aggregation": {"alignmentPeriod": "60s", "perSeriesAligner": "ALIGN_PERCENTILE_95", "crossSeriesReducer": "REDUCE_MEAN"}}}, "plotType": "LINE", "legendTemplate": "p95"},
              {"timeSeriesQuery": {"timeSeriesFilter": {"filter": "metric.type=\"run.googleapis.com/request_latencies\" resource.type=\"cloud_run_revision\" resource.labels.project_id=\"${project_id}\"", "aggregation": {"alignmentPeriod": "60s", "perSeriesAligner": "ALIGN_PERCENTILE_99", "crossSeriesReducer": "REDUCE_MEAN"}}}, "plotType": "LINE", "legendTemplate": "p99"}
            ]
          }
        }
      },
      {
        "width": 6, "height": 4, "xPos": 0, "yPos": 4,
        "widget": {
          "title": "Error rate (5xx / total) (${env})",
          "xyChart": {
            "dataSets": [{
              "timeSeriesQuery": {
                "timeSeriesFilterRatio": {
                  "numerator": {"filter": "metric.type=\"run.googleapis.com/request_count\" resource.type=\"cloud_run_revision\" resource.labels.project_id=\"${project_id}\" metric.label.response_code_class=\"5xx\"", "aggregation": {"alignmentPeriod": "60s", "perSeriesAligner": "ALIGN_RATE", "crossSeriesReducer": "REDUCE_SUM"}},
                  "denominator": {"filter": "metric.type=\"run.googleapis.com/request_count\" resource.type=\"cloud_run_revision\" resource.labels.project_id=\"${project_id}\"", "aggregation": {"alignmentPeriod": "60s", "perSeriesAligner": "ALIGN_RATE", "crossSeriesReducer": "REDUCE_SUM"}}
                }
              },
              "plotType": "LINE"
            }]
          }
        }
      },
      {
        "width": 6, "height": 4, "xPos": 6, "yPos": 4,
        "widget": {
          "title": "Instance count (${env})",
          "xyChart": {
            "dataSets": [{
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"run.googleapis.com/container/instance_count\" resource.type=\"cloud_run_revision\" resource.labels.project_id=\"${project_id}\"",
                  "aggregation": {"alignmentPeriod": "60s", "perSeriesAligner": "ALIGN_MEAN", "crossSeriesReducer": "REDUCE_SUM", "groupByFields": ["resource.labels.service_name"]}
                }
              },
              "plotType": "LINE"
            }]
          }
        }
      },
      {
        "width": 6, "height": 4, "xPos": 0, "yPos": 8,
        "widget": {
          "title": "CPU utilization (${env})",
          "xyChart": {
            "dataSets": [{
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"run.googleapis.com/container/cpu/utilizations\" resource.type=\"cloud_run_revision\" resource.labels.project_id=\"${project_id}\"",
                  "aggregation": {"alignmentPeriod": "60s", "perSeriesAligner": "ALIGN_PERCENTILE_95", "crossSeriesReducer": "REDUCE_MEAN"}
                }
              },
              "plotType": "LINE"
            }]
          }
        }
      },
      {
        "width": 6, "height": 4, "xPos": 6, "yPos": 8,
        "widget": {
          "title": "Memory utilization (${env})",
          "xyChart": {
            "dataSets": [{
              "timeSeriesQuery": {
                "timeSeriesFilter": {
                  "filter": "metric.type=\"run.googleapis.com/container/memory/utilizations\" resource.type=\"cloud_run_revision\" resource.labels.project_id=\"${project_id}\"",
                  "aggregation": {"alignmentPeriod": "60s", "perSeriesAligner": "ALIGN_PERCENTILE_95", "crossSeriesReducer": "REDUCE_MEAN"}
                }
              },
              "plotType": "LINE"
            }]
          }
        }
      }
    ]
  }
}
