# Copy to .env.docker; used by interview-assistant service via env_file directive in docker-compose.yml.
# This file is gitignored at the .env* pattern; .example is committed for reference.

# OpenAI API key for LLM scoring + AI trainer
OPENAI_API_KEY=

# GitHub token for question-bank loader
GITHUB_TOKEN=

# Resend API key for email delivery
RESEND_API_KEY=

# Supabase connection (mirror from .env.example)
DATABASE_URL=
DIRECT_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_EMAILS=

# LangSmith tracing (optional)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=

# Judge0 wiring (Phase 38)
JUDGE0_URL=http://judge0-server:2358
JUDGE0_AUTH_TOKEN=must-match-.env.judge0-JUDGE0_AUTH_TOKEN
JUDGE0_EXPOSE_LOCAL=true
