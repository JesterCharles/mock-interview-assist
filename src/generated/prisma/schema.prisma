generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Connectivity test table — proves the pipeline works
model HealthCheck {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
}

model Associate {
  id              Int        @id @default(autoincrement())
  slug            String     @unique
  displayName     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  readinessStatus String? // 'ready' | 'improving' | 'not_ready'
  recommendedArea String? // topic or skill name — lowest gap score
  lastComputedAt  DateTime? // when readiness was last computed
  sessions        Session[]
  gapScores       GapScore[]
}

model Session {
  id                    String     @id
  candidateName         String?
  interviewerName       String?
  date                  String
  status                String
  questionCount         Int
  selectedWeeks         Json
  overallTechnicalScore Float?
  overallSoftSkillScore Float?
  technicalFeedback     String?
  softSkillFeedback     String?
  questions             Json
  starterQuestions      Json
  assessments           Json
  techMap               Json? // Record<number, string> mapping weekNumber -> skill name
  associateId           Int?
  associate             Associate? @relation(fields: [associateId], references: [id])
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

model GapScore {
  id            String   @id @default(cuid())
  associateId   Int
  skill         String
  topic         String   @default("")
  weightedScore Float
  sessionCount  Int
  lastUpdated   DateTime @updatedAt

  associate Associate @relation(fields: [associateId], references: [id], onDelete: Cascade)

  @@unique([associateId, skill, topic])
  @@index([associateId])
}
