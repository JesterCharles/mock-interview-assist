# Judge0 sandbox env — used by judge0-server, judge0-workers, judge0-db, judge0-redis
# Copy to .env.judge0 (gitignored) and fill in real values before `docker compose up`.
# DO NOT commit .env.judge0.

# ----- Auth (D-10) -----
# Shared secret between Judge0 server and the app's judge0Client.ts.
# Generate: openssl rand -hex 32
JUDGE0_AUTH_TOKEN=replace-with-openssl-rand-hex-32

# ----- Judge0 Postgres -----
# Generate: openssl rand -base64 24
JUDGE0_DB_PASSWORD=replace-with-strong-password

# ----- Judge0 Redis -----
# Generate: openssl rand -base64 24
JUDGE0_REDIS_PASSWORD=replace-with-strong-password

# ----- Worker count (D-07) -----
# Leave blank to use Judge0 default (2 × vCPU).
# Override to a specific integer during Phase 38-03 spike (e.g., 2, 4, 8).
COUNT_WORKERS=
