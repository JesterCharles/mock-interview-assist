# Judge0 sandbox env — used by judge0-server, judge0-workers, judge0-db, judge0-redis
# Copy to .env.judge0 (gitignored) and fill in real values before `docker compose up`.
# DO NOT commit .env.judge0.

# ----- Auth (D-10) -----
# Shared secret between Judge0 server and the app's judge0Client.ts.
# Generate: openssl rand -hex 32
JUDGE0_AUTH_TOKEN=replace-with-openssl-rand-hex-32

# ----- Judge0 Postgres -----
# Generate: openssl rand -base64 24
JUDGE0_DB_PASSWORD=replace-with-strong-password

# ----- Judge0 Redis -----
# Generate: openssl rand -base64 24
JUDGE0_REDIS_PASSWORD=replace-with-strong-password

# ----- Worker count (D-07) -----
# Leave blank to use Judge0 default (2 × vCPU).
# Override to a specific integer during Phase 38-03 spike (e.g., 2, 4, 8).
COUNT_WORKERS=

# ----- Port exposure (D-09) -----
# The base docker-compose.yml NEVER publishes port 2358. The app container
# reaches judge0-server over the internal judge0-net bridge by service name.
#
# For LOCAL DEBUG ONLY (curl, spike harness from host), opt in by merging the
# overlay file:
#   docker compose -f docker-compose.yml -f docker-compose.expose-judge0.yml up
#
# PRODUCTION: do NOT pass the overlay file. Judge0 stays private to the
# judge0-net bridge. This variable is informational — the actual gate is
# whether docker-compose.expose-judge0.yml is merged in.
JUDGE0_EXPOSE_LOCAL=false
