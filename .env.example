# Runtime queries — Supabase Transaction Pooler (port 6543)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?connection_limit=5&pool_timeout=10"

# Migrations only — Direct Supabase connection (port 5432)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres"

# ─── Supabase Auth (Phase 18+) ───────────────────────────────────────────────
# Supabase project URL — Supabase Dashboard -> Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://[your-project-ref].supabase.co

# Supabase publishable key — Supabase Dashboard -> Settings -> API -> publishable key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase secret key (server-only, never expose to browser)
# Supabase Dashboard -> Settings -> API -> secret key
SUPABASE_SECRET_KEY=

# Production site URL — used for OAuth redirects and boot-time safety assertion.
# Must NOT be localhost/127.0.0.1 in production. Use http://localhost:3000 for local dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated admin email addresses for password-reset abuse flag notifications.
# Example: admin@example.com,security@example.com
ADMIN_EMAILS=

# ============================================================
# Judge0 coding sandbox (v1.4 — Phase 38)
# ============================================================
# URL the app's judge0Client.ts targets. In docker compose, use service name.
# In remote-MSA deploy (Phase 43), use the private Judge0 host URL.
JUDGE0_URL=http://judge0-server:2358

# Shared secret with the Judge0 server. Must match JUDGE0_AUTH_TOKEN in .env.judge0.
JUDGE0_AUTH_TOKEN=replace-with-matching-token

# If "true", docker-compose binds judge0-server:2358 to 127.0.0.1 for local debugging.
# Set to "false" in production compose files.
JUDGE0_EXPOSE_LOCAL=true
