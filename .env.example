# Runtime queries — Supabase Transaction Pooler (port 6543)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?connection_limit=5&pool_timeout=10"

# Migrations only — Direct Supabase connection (port 5432)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres"

# Dedicated HMAC secret for associate_session cookies. Generate with: openssl rand -hex 32
# Do NOT reuse APP_PASSWORD — associate and trainer secrets are intentionally decoupled
# so trainer-password rotation does not invalidate associate sessions.
ASSOCIATE_SESSION_SECRET=

# ─── Supabase Auth (Phase 18+) ───────────────────────────────────────────────
# Supabase project URL — Supabase Dashboard -> Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://[your-project-ref].supabase.co

# Supabase anon/public key — Supabase Dashboard -> Settings -> API -> anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server-only, never expose to browser)
# Supabase Dashboard -> Settings -> API -> service_role secret key
SUPABASE_SERVICE_ROLE_KEY=

# Production site URL — used for OAuth redirects and boot-time safety assertion.
# Must NOT be localhost/127.0.0.1 in production. Use http://localhost:3000 for local dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Comma-separated admin email addresses for password-reset abuse flag notifications.
# Example: admin@example.com,security@example.com
ADMIN_EMAILS=
